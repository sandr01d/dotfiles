          "mode-mon-col": 3,
          "weeks-pos": "right",
          "iso8601": true,
          "format": {
            "days": "<span color='#FFFFFF'><b>{}</b></span>",
            "weeks": "<span color='#3f3f3f'><b>W{}</b></span>",
